/**
 * 添加产品页样式
 * 设计参考: design-system/MASTER.md + design-system/pages/add.md
 */

.page-add {
  padding: var(--space-lg);
  padding-bottom: 120px;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 模式切换 Tab — 胶囊样式 */
.mode-switcher {
  display: flex;
  background-color: var(--color-bg);
  border-radius: var(--radius-button);
  padding: 3px;
  margin-bottom: var(--space-xl);
  border: 1px solid var(--color-border);
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: var(--space-sm) 0;
  font-size: var(--font-body-size);
  font-weight: 600;
  color: var(--color-text-secondary);
  border-radius: 10px;
  transition: all 200ms ease;
}

.mode-tab-active {
  background-color: var(--color-primary);
  color: #FFFFFF;
  box-shadow: 0 2px 8px rgba(255, 107, 138, 0.3);
}

/* 链接导入区域 */
.link-section {
  margin-bottom: var(--space-xl);
}

.link-input-row {
  display: flex;
  gap: var(--space-sm);
  align-items: center;
}

.link-input {
  flex: 1;
}

.btn-parse {
  flex-shrink: 0;
  padding: 0 var(--space-lg);
  height: 44px;
  line-height: 44px;
  font-size: var(--font-body-size);
}

/* 解析结果提示 */
.parse-result {
  margin-top: var(--space-md);
  padding: var(--space-md) var(--space-lg);
  border-radius: var(--radius-input);
  font-size: var(--font-caption-size);
}

.parse-success {
  background-color: var(--color-safe-bg);
  color: #059669;
}

.parse-fail {
  background-color: var(--color-danger-bg);
  color: #DC2626;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.switch-manual {
  color: var(--color-primary);
  font-weight: 600;
  text-decoration: underline;
}

/* 表单区域 */
.form-section {
  margin-bottom: var(--space-xl);
}

.form-item {
  margin-bottom: var(--space-lg);
}

.form-label {
  display: block;
  font-size: var(--font-caption-size);
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: var(--space-xs);
}

.required {
  color: var(--color-danger);
}

/* 分类标签组 */
.category-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.category-tag {
  padding: var(--space-xs) var(--space-md);
  border-radius: var(--radius-tag);
  font-size: var(--font-caption-size);
  font-weight: 600;
  color: var(--color-text-secondary);
  background-color: var(--color-surface);
  border: 1px solid var(--color-border);
  transition: all 200ms ease;
}

.category-tag-active {
  background-color: var(--color-primary);
  color: #FFFFFF;
  border-color: var(--color-primary);
}

/* 分类空状态 */
.category-empty {
  padding: var(--space-md) var(--space-lg);
  background-color: var(--color-surface);
  border-radius: var(--radius-input);
  border: 1px dashed var(--color-border);
  font-size: var(--font-caption-size);
  color: var(--color-text-tertiary);
}

.category-empty-link {
  color: var(--color-primary);
  font-weight: 600;
  text-decoration: underline;
}

/* 日期选择器 */
.picker-value {
  display: flex;
  align-items: center;
}

.placeholder {
  color: var(--color-text-tertiary);
}

/* 过期时间预览 */
.expiry-preview {
  margin-top: calc(-1 * var(--space-sm));
  margin-bottom: var(--space-lg);
}

.expiry-preview-inner {
  background-color: var(--color-info-bg);
  border-radius: var(--radius-input);
  padding: var(--space-md) var(--space-lg);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.expiry-label {
  font-size: var(--font-caption-size);
  color: #2563EB;
  font-weight: 600;
}

.expiry-date {
  font-size: var(--font-body-size);
  color: #1D4ED8;
  font-weight: 700;
}

/* 开封区域 */
.opened-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.toggle-icon {
  font-size: var(--font-caption-size);
  color: var(--color-primary);
  font-weight: 600;
}

/* 保存按钮 */
.save-section {
  padding: var(--space-lg) 0;
}

.btn-save {
  width: 100%;
  height: 48px;
  line-height: 48px;
  font-size: var(--font-h3-size);
  padding: 0;
}

.btn-save[disabled] {
  opacity: 0.6;
}
