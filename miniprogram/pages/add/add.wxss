/**
 * 添加产品页样式 — 暖暖梦幻版
 * 天蓝渐变按钮 + 柔和输入框 + 清新标签
 */

.page-add {
  padding: var(--space-lg);
  padding-bottom: 120px;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 模式切换 Tab — 梦幻胶囊样式 */
.mode-switcher {
  display: flex;
  background-color: var(--color-surface);
  border-radius: var(--radius-button);
  padding: 3px;
  margin-bottom: var(--space-xl);
  border: 1px solid rgba(93, 168, 208, 0.10);
  box-shadow: var(--shadow-card);
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: var(--space-sm) 0;
  font-size: var(--font-body-size);
  font-weight: 600;
  color: var(--color-text-secondary);
  border-radius: 12px;
  transition: all 250ms ease;
}

.mode-tab-active {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: #FFFFFF;
  box-shadow: 0 3px 10px rgba(93, 168, 208, 0.30);
}

/* 拍照识别区域 */
.image-section {
  margin-bottom: var(--space-xl);
}

/* 上传引导区 — 天蓝色调 */
.image-upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-2xl) var(--space-lg);
  background: linear-gradient(135deg, rgba(232, 244, 252, 0.5), rgba(226, 246, 237, 0.3));
  border: 2px dashed rgba(93, 168, 208, 0.20);
  border-radius: var(--radius-card);
  transition: all 200ms ease;
}

.image-upload-area:active {
  background: linear-gradient(135deg, rgba(232, 244, 252, 0.8), rgba(226, 246, 237, 0.5));
  border-color: var(--color-primary-light);
}

.upload-icon-wrapper {
  width: 64px;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-primary-bg), var(--color-secondary-bg));
  border-radius: var(--radius-icon);
  margin-bottom: var(--space-md);
  box-shadow: var(--shadow-glow);
}

.upload-icon {
  width: 36px;
  height: 36px;
}

.upload-title {
  font-size: var(--font-body-size);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--space-xs);
}

.upload-hint {
  font-size: var(--font-caption-size);
  color: var(--color-text-tertiary);
}

/* 图片预览区 */
.image-preview-area {
  position: relative;
  border-radius: var(--radius-card);
  overflow: hidden;
  background-color: var(--color-surface);
  border: 1px solid rgba(93, 168, 208, 0.08);
}

.image-preview {
  width: 100%;
  height: 200px;
  display: block;
}

.image-preview-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: rgba(45, 52, 54, 0.40);
  backdrop-filter: blur(3px);
  -webkit-backdrop-filter: blur(3px);
}

.recognizing-spinner {
  width: 32px;
  height: 32px;
  border: 3px solid rgba(255, 255, 255, 0.25);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: var(--space-sm);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.recognizing-text {
  font-size: var(--font-body-size);
  color: #FFFFFF;
  font-weight: 600;
}

.image-actions {
  display: flex;
  justify-content: center;
  padding: var(--space-sm);
  background-color: var(--color-surface);
}

.image-action-btn {
  font-size: var(--font-caption-size);
  color: var(--color-primary);
  font-weight: 600;
  padding: var(--space-xs) var(--space-md);
}

/* 识别结果提示 */
.parse-result {
  margin-top: var(--space-md);
  padding: var(--space-md) var(--space-lg);
  border-radius: var(--radius-input);
  font-size: var(--font-caption-size);
}

.parse-success {
  background-color: var(--color-safe-bg);
  color: #2D9B72;
}

.parse-warning {
  background-color: var(--color-warning-bg);
  color: #8B6914;
  margin-top: var(--space-sm);
}

.warning-title {
  display: block;
  font-size: var(--font-caption-size);
  font-weight: 600;
  margin-bottom: var(--space-xs);
}

.defaulted-field-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
}

.defaulted-field-tag {
  display: inline-block;
  padding: 2px 8px;
  border-radius: var(--radius-tag);
  background-color: rgba(232, 168, 56, 0.20);
  color: #8B6914;
  font-size: var(--font-caption-size);
  font-weight: 600;
}

.parse-fail {
  background-color: var(--color-danger-bg);
  color: #C74B4B;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.switch-manual {
  color: var(--color-primary);
  font-weight: 600;
  text-decoration: underline;
}

/* 表单区域 */
.form-section {
  margin-bottom: var(--space-xl);
}

.form-item {
  margin-bottom: var(--space-lg);
}

.form-label {
  display: block;
  font-size: var(--font-caption-size);
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: var(--space-xs);
}

.required {
  color: var(--color-danger);
}

/* 分类标签组 — 天蓝风格 */
.category-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.category-tag {
  padding: var(--space-xs) var(--space-md);
  border-radius: var(--radius-tag);
  font-size: var(--font-caption-size);
  font-weight: 600;
  color: var(--color-text-secondary);
  background-color: var(--color-surface);
  border: 1px solid rgba(93, 168, 208, 0.12);
  transition: all 200ms ease;
}

.category-tag-active {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: #FFFFFF;
  border-color: transparent;
  box-shadow: 0 2px 6px rgba(93, 168, 208, 0.20);
}

.category-tag-add {
  color: var(--color-primary);
  border-color: rgba(93, 168, 208, 0.25);
  background-color: var(--color-primary-bg);
  min-width: 36px;
  text-align: center;
  font-size: var(--font-body-size);
}

/* 分类空状态 */
.category-empty {
  padding: var(--space-md) var(--space-lg);
  background-color: var(--color-surface);
  border-radius: var(--radius-input);
  border: 1px dashed rgba(93, 168, 208, 0.15);
  font-size: var(--font-caption-size);
  color: var(--color-text-tertiary);
}

.category-empty-link {
  color: var(--color-primary);
  font-weight: 600;
  text-decoration: underline;
}

/* 日期选择器 */
.picker-value {
  display: flex;
  align-items: center;
}

.placeholder {
  color: var(--color-text-tertiary);
}

/* 过期时间预览 */
.expiry-preview {
  margin-top: calc(-1 * var(--space-sm));
  margin-bottom: var(--space-lg);
}

.expiry-preview-inner {
  background: linear-gradient(135deg, var(--color-info-bg), rgba(226, 241, 248, 0.5));
  border-radius: var(--radius-input);
  padding: var(--space-md) var(--space-lg);
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1px solid rgba(107, 174, 208, 0.12);
}

.expiry-label {
  font-size: var(--font-caption-size);
  color: #3A8DBF;
  font-weight: 600;
}

.expiry-date {
  font-size: var(--font-body-size);
  color: #2171A8;
  font-weight: 700;
}

/* 开封区域 */
.opened-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.toggle-icon {
  font-size: var(--font-caption-size);
  color: var(--color-primary);
  font-weight: 600;
}

/* 保存按钮 — 渐变天空蓝 + 发光效果 */
.save-section {
  padding: var(--space-lg) 0;
}

.btn-save {
  width: 100%;
  height: 48px;
  line-height: 48px;
  font-size: var(--font-h3-size);
  padding: 0;
  box-shadow: 0 4px 16px rgba(93, 168, 208, 0.30);
}

.btn-save[disabled] {
  opacity: 0.55;
}
