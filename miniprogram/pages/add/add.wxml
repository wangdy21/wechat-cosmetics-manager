<!--
  添加产品页
  双模式：拍照识别 / 手动录入
  设计参考: design-system/pages/add.md
-->
<view class="page-add">

  <!-- 模式切换 Tab -->
  <view class="mode-switcher">
    <view
      class="mode-tab {{mode === 'image' ? 'mode-tab-active' : ''}}"
      bindtap="switchMode"
      data-mode="image"
    >拍照识别</view>
    <view
      class="mode-tab {{mode === 'manual' ? 'mode-tab-active' : ''}}"
      bindtap="switchMode"
      data-mode="manual"
    >手动录入</view>
  </view>

  <!-- 拍照识别区域 -->
  <view class="image-section" wx:if="{{mode === 'image'}}">

    <!-- 未选择图片时：上传引导区 -->
    <view class="image-upload-area" bindtap="onChooseImage" wx:if="{{!imagePath && !recognizing}}">
      <view class="upload-icon-wrapper">
        <!-- 相机图标 SVG -->
        <image class="upload-icon" src="/images/camera.svg" mode="aspectFit" />
      </view>
      <text class="upload-title">拍照或选择商品包装图片</text>
      <text class="upload-hint">支持商品包装、标签、参数截图</text>
    </view>

    <!-- 已选择图片：预览 + 识别中状态 -->
    <view class="image-preview-area" wx:if="{{imagePath}}">
      <image class="image-preview" src="{{imagePath}}" mode="aspectFill" bindtap="onChooseImage" />
      <view class="image-preview-overlay" wx:if="{{recognizing}}">
        <view class="recognizing-spinner"></view>
        <text class="recognizing-text">正在识别...</text>
      </view>
      <view class="image-actions" wx:if="{{!recognizing}}">
        <text class="image-action-btn" bindtap="onChooseImage">重新选择</text>
      </view>
    </view>

    <!-- 识别失败提示 -->
    <view class="parse-result parse-fail" wx:if="{{recognizeStatus === 'fail'}}">
      <text>{{recognizeError}}</text>
      <text class="switch-manual" bindtap="switchToManual">切换手动录入</text>
    </view>
  </view>

  <!-- 识别成功提示（全局显示，不受模式切换影响） -->
  <view class="parse-result parse-success" wx:if="{{recognizeStatus === 'success'}}">
    <text>识别成功：{{parsedName}}</text>
  </view>

  <!-- 默认值填充提醒 -->
  <view class="parse-result parse-warning" wx:if="{{recognizeStatus === 'success' && defaultedFields.length > 0}}">
    <text class="warning-title">以下必填字段已自动填充默认值，请核实修改：</text>
    <view class="defaulted-field-list">
      <text class="defaulted-field-tag" wx:for="{{defaultedFields}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <!-- 表单区域 -->
  <view class="form-section">
    <!-- 品牌 -->
    <view class="form-item">
      <text class="form-label">品牌</text>
      <input
        class="input"
        placeholder="如：兰蔻"
        value="{{form.brand}}"
        bindinput="onFormInput"
        data-field="brand"
      />
    </view>

    <!-- 名称 -->
    <view class="form-item">
      <text class="form-label">名称 <text class="required">*</text></text>
      <input
        class="input"
        placeholder="如：小黑瓶精华肌底液"
        value="{{form.name}}"
        bindinput="onFormInput"
        data-field="name"
      />
    </view>

    <!-- 分类选择 -->
    <view class="form-item">
      <text class="form-label">分类 <text class="required">*</text></text>
      <view class="category-tags">
        <view
          wx:for="{{categories}}"
          wx:key="_id"
          class="category-tag {{form.category === item.name ? 'category-tag-active' : ''}}"
          bindtap="onCategoryTap"
          data-name="{{item.name}}"
        >{{item.name}}</view>
        <view class="category-tag category-tag-add" bindtap="onAddCategory">+</view>
      </view>
    </view>

    <!-- 规格 -->
    <view class="form-item">
      <text class="form-label">规格</text>
      <input
        class="input"
        placeholder="如：50ml"
        value="{{form.specification}}"
        bindinput="onFormInput"
        data-field="specification"
      />
    </view>

    <!-- 生产日期 -->
    <view class="form-item">
      <text class="form-label">生产日期 <text class="required">*</text></text>
      <picker
        mode="date"
        value="{{form.productionDate}}"
        end="{{today}}"
        bindchange="onDateChange"
        data-field="productionDate"
      >
        <view class="input picker-value {{form.productionDate ? '' : 'placeholder'}}">
          {{form.productionDate || '请选择生产日期'}}
        </view>
      </picker>
    </view>

    <!-- 保质期 -->
    <view class="form-item">
      <text class="form-label">保质期（月） <text class="required">*</text></text>
      <input
        class="input"
        type="number"
        placeholder="如：36"
        value="{{form.shelfLifeMonths}}"
        bindinput="onFormInput"
        data-field="shelfLifeMonths"
      />
    </view>

    <!-- 过期时间自动计算预览 -->
    <view class="expiry-preview" wx:if="{{expiryPreview}}">
      <view class="expiry-preview-inner">
        <text class="expiry-label">预计过期日期</text>
        <text class="expiry-date">{{expiryPreview}}</text>
      </view>
    </view>

    <!-- 开封信息（折叠区域） -->
    <view class="form-item">
      <view class="opened-toggle" bindtap="toggleOpened">
        <text class="form-label">已开封？</text>
        <text class="toggle-icon">{{showOpened ? '收起' : '展开'}}</text>
      </view>
    </view>

    <block wx:if="{{showOpened}}">
      <!-- 开封日期 -->
      <view class="form-item">
        <text class="form-label">开封日期</text>
        <picker
          mode="date"
          value="{{form.openedDate}}"
          start="{{form.productionDate}}"
          end="{{today}}"
          bindchange="onDateChange"
          data-field="openedDate"
        >
          <view class="input picker-value {{form.openedDate ? '' : 'placeholder'}}">
            {{form.openedDate || '请选择开封日期'}}
          </view>
        </picker>
      </view>

      <!-- 开封后保质期 -->
      <view class="form-item">
        <text class="form-label">开封后保质期（月）</text>
        <input
          class="input"
          type="number"
          placeholder="如：12"
          value="{{form.openedShelfLifeMonths}}"
          bindinput="onFormInput"
          data-field="openedShelfLifeMonths"
        />
      </view>
    </block>
  </view>

  <!-- 保存按钮 -->
  <view class="save-section">
    <button
      class="btn-primary btn-save"
      bindtap="onSaveTap"
      disabled="{{saving}}"
    >
      <text wx:if="{{!saving}}">保存产品</text>
      <text wx:else>保存中...</text>
    </button>
  </view>

</view>
