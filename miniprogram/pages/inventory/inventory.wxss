/**
 * 库存页样式 — 暖暖梦幻版
 * 天蓝色系搜索栏 + 柔和标签 + 清新卡片列表
 */

.page-inventory {
  padding: var(--space-lg);
  padding-bottom: 80px;
  min-height: 100vh;
  box-sizing: border-box;
  background: var(--color-bg);
}

/* 搜索栏 — 天蓝边框 + 柔和阴影 */
.search-bar {
  display: flex;
  align-items: center;
  background-color: var(--color-surface);
  border-radius: var(--radius-input);
  box-shadow: var(--shadow-card);
  padding: 0 var(--space-lg);
  height: 42px;
  margin-bottom: var(--space-lg);
  border: 1px solid rgba(93, 168, 208, 0.10);
}

.search-icon {
  margin-right: var(--space-sm);
}

.search-icon-text {
  font-size: 16px;
  font-weight: 700;
  color: var(--color-primary);
}

.search-input {
  flex: 1;
  font-size: var(--font-body-size);
  color: var(--color-text-primary);
  height: 42px;
}

/* 分类标签行 — 胶囊风格 */
.category-scroll {
  white-space: nowrap;
  margin-bottom: var(--space-md);
}

.filter-tag {
  display: inline-block;
  padding: var(--space-xs) var(--space-md);
  border-radius: var(--radius-tag);
  font-size: var(--font-caption-size);
  font-weight: 600;
  color: var(--color-text-secondary);
  background-color: var(--color-surface);
  border: 1px solid rgba(93, 168, 208, 0.12);
  margin-right: var(--space-sm);
  transition: all 200ms ease;
}

.filter-tag-active {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: #FFFFFF;
  border-color: transparent;
  box-shadow: 0 2px 8px rgba(93, 168, 208, 0.25);
}

/* 状态过滤标签 — 柔和渐变 */
.status-filters {
  display: flex;
  gap: var(--space-sm);
  margin-bottom: var(--space-xl);
}

.status-tag {
  flex: 1;
  text-align: center;
  padding: var(--space-xs) 0;
  border-radius: var(--radius-tag);
  font-size: var(--font-caption-size);
  font-weight: 600;
  transition: all 200ms ease;
  opacity: 0.45;
}

.status-tag-active {
  opacity: 1;
  transform: scale(1.02);
}

.status-safe {
  background-color: var(--color-safe-bg);
  color: #2D9B72;
}

.status-warning {
  background-color: var(--color-warning-bg);
  color: #C87D0A;
}

.status-danger {
  background-color: var(--color-danger-bg);
  color: #C74B4B;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-2xl) 0;
}

.empty-icon {
  width: 80px;
  height: 80px;
  border-radius: var(--radius-full);
  background: linear-gradient(135deg, var(--color-primary-bg), var(--color-secondary-bg));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-lg);
  box-shadow: var(--shadow-glow);
}

.empty-icon-text {
  font-size: 32px;
  color: var(--color-primary);
}

.empty-title {
  font-size: var(--font-h3-size);
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: var(--space-xs);
}

.empty-desc {
  font-size: var(--font-caption-size);
  color: var(--color-text-secondary);
  margin-bottom: var(--space-xl);
}

.btn-empty {
  padding: var(--space-md) var(--space-2xl);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: var(--space-lg) 0;
}

.load-more-text {
  font-size: var(--font-caption-size);
  color: var(--color-primary);
  font-weight: 600;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: var(--space-xl) 0;
}

.loading-text {
  font-size: var(--font-caption-size);
  color: var(--color-text-tertiary);
}
