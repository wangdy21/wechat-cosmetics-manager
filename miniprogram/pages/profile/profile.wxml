<!--
  个人中心页
  用户信息 + 库存统计 + 设置列表
  设计参考: design-system/pages/profile.md
-->
<view class="page-profile">

  <!-- 用户信息区 -->
  <view class="profile-header">
    <view class="avatar">
      <text class="avatar-text">U</text>
    </view>
    <view class="profile-info">
      <text class="profile-title">我的美妆库</text>
      <text class="profile-count">共 {{totalProducts}} 件产品</text>
    </view>
  </view>

  <!-- 库存统计 -->
  <view class="section" wx:if="{{categoryStats.length > 0}}">
    <text class="section-label">库存统计</text>
    <view class="category-stats">
      <view
        wx:for="{{categoryStats}}"
        wx:key="name"
        class="cat-stat-card cat-bg-{{index % 3}}"
      >
        <text class="cat-stat-num">{{item.count}}</text>
        <text class="cat-stat-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 设置列表 · 提醒设置 -->
  <view class="section">
    <text class="section-label">提醒设置</text>
    <view class="settings-group card">
      <view class="setting-item">
        <text class="setting-name">提前提醒天数</text>
        <view class="setting-right">
          <text class="setting-value">{{advanceDays}} 天</text>
          <text class="setting-arrow">></text>
        </view>
      </view>
      <view class="setting-item">
        <text class="setting-name">推送通知</text>
        <switch
          class="setting-switch"
          checked="{{enablePush}}"
          bindchange="onPushToggle"
          color="#FF6B8A"
        />
      </view>
      <view class="setting-item" wx:if="{{enablePush}}">
        <text class="setting-name">推送频率</text>
        <view class="setting-right">
          <text class="setting-value">{{pushFrequency === 'daily' ? '每天' : '每周'}}</text>
          <text class="setting-arrow">></text>
        </view>
      </view>
    </view>
  </view>

  <!-- 设置列表 · 管理 -->
  <view class="section">
    <text class="section-label">管理</text>
    <view class="settings-group card">
      <view class="setting-item" bindtap="goCategory">
        <text class="setting-name">分类管理</text>
        <view class="setting-right">
          <text class="setting-arrow">></text>
        </view>
      </view>
    </view>
  </view>

</view>
