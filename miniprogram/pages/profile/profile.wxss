/**
 * 个人中心页样式 — 暖暖梦幻版
 * 角色展示区 + 渐变背景 + 柔和卡片
 */

.page-profile {
  padding-bottom: 80px;
  min-height: 100vh;
  background: var(--color-bg);
}

/* ====== 头部角色展示区 ====== */
.profile-header {
  position: relative;
  background: linear-gradient(
    160deg,
    #7EC8E3 0%,
    #A8DDEE 30%,
    #C5EBF0 55%,
    #D4F0E2 80%,
    #E2F6ED 100%
  );
  padding: var(--space-xl) var(--space-lg) var(--space-2xl);
  overflow: hidden;
  border-radius: 0 0 32px 32px;
}

/* 梦幻装饰 */
.profile-deco {
  position: absolute;
  pointer-events: none;
  border-radius: 50%;
  opacity: 0.4;
}

.profile-deco-1 {
  width: 100px;
  height: 100px;
  background: rgba(255, 255, 255, 0.15);
  top: -30px;
  right: -20px;
  filter: blur(8px);
}

.profile-deco-2 {
  width: 60px;
  height: 60px;
  background: rgba(168, 230, 207, 0.20);
  bottom: 10px;
  left: -10px;
  filter: blur(5px);
}

.profile-deco-3 {
  width: 30px;
  height: 30px;
  background: rgba(232, 184, 109, 0.18);
  top: 40%;
  right: 60px;
  filter: blur(3px);
}

.profile-header-inner {
  display: flex;
  align-items: center;
  gap: var(--space-lg);
  position: relative;
  z-index: 2;
}

/* 暖暖角色大图展示 */
.character-showcase {
  width: 68px;
  height: 68px;
  border-radius: 24px;
  overflow: hidden;
  flex-shrink: 0;
  border: 3px solid rgba(255, 255, 255, 0.55);
  box-shadow:
    0 6px 24px rgba(93, 168, 208, 0.22),
    0 0 0 1px rgba(255, 255, 255, 0.25);
  animation: float-gentle 3s ease-in-out infinite;
}

.character-showcase-img {
  width: 100%;
  height: 100%;
}

@keyframes float-gentle {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-4px); }
}

.profile-info {
  flex: 1;
}

.profile-title {
  display: block;
  font-size: var(--font-h2-size);
  font-weight: 800;
  color: var(--color-text-primary);
  text-shadow: 0 1px 4px rgba(255, 255, 255, 0.35);
}

.profile-subtitle {
  display: block;
  font-size: var(--font-caption-size);
  color: rgba(45, 52, 54, 0.50);
  margin-top: 4px;
  font-weight: 500;
}

.profile-count {
  display: block;
  font-size: var(--font-caption-size);
  color: var(--color-text-secondary);
  margin-top: 2px;
}

/* ====== 区块 ====== */
.section {
  padding: var(--space-xl) var(--space-lg) 0;
}

.section-label {
  display: block;
  font-size: var(--font-caption-size);
  font-weight: 700;
  color: var(--color-text-tertiary);
  margin-bottom: var(--space-sm);
  letter-spacing: 0.5px;
}

/* ====== 库存统计卡片 — 柔和渐变 ====== */
.category-stats {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.cat-stat-card {
  flex: 1;
  min-width: 80px;
  border-radius: var(--radius-card);
  padding: var(--space-md);
  text-align: center;
  box-shadow: var(--shadow-card);
}

.cat-bg-0 { background: linear-gradient(135deg, #E8F4FC, #C5E8F5); }
.cat-bg-1 { background: linear-gradient(135deg, #E8F5EF, #C5EDE0); }
.cat-bg-2 { background: linear-gradient(135deg, #FBF6EE, #F5ECD8); }

.cat-stat-num {
  display: block;
  font-size: 18px;
  font-weight: 800;
  color: var(--color-text-primary);
}

.cat-stat-name {
  display: block;
  font-size: var(--font-small-size);
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-top: 2px;
}

/* ====== 设置列表 ====== */
.settings-group {
  padding: 0;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 52px;
  padding: 0 var(--space-lg);
  border-bottom: 1px solid rgba(93, 168, 208, 0.06);
  transition: background-color 150ms ease;
}

.setting-item:active {
  background-color: rgba(93, 168, 208, 0.04);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-name {
  font-size: var(--font-body-size);
  color: var(--color-text-primary);
  font-weight: 500;
}

.setting-right {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.setting-value {
  font-size: var(--font-body-size);
  color: var(--color-text-secondary);
}

.setting-arrow {
  font-size: 16px;
  color: var(--color-text-tertiary);
  font-weight: 300;
}

.setting-switch {
  transform: scale(0.85);
}
