/**
 * 编辑产品页样式 — 暖暖梦幻版
 * 与添加页保持一致的清新天蓝风格
 */

.page-edit {
  padding: var(--space-lg);
  padding-bottom: 120px;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 表单区域 */
.form-section {
  margin-bottom: var(--space-xl);
}

.form-item {
  margin-bottom: var(--space-lg);
}

.form-label {
  display: block;
  font-size: var(--font-caption-size);
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: var(--space-xs);
}

.required {
  color: var(--color-danger);
}

/* 分类标签组 — 天蓝风格 */
.category-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.category-tag {
  padding: var(--space-xs) var(--space-md);
  border-radius: var(--radius-tag);
  font-size: var(--font-caption-size);
  font-weight: 600;
  color: var(--color-text-secondary);
  background-color: var(--color-surface);
  border: 1px solid rgba(93, 168, 208, 0.12);
  transition: all 200ms ease;
}

.category-tag-active {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: #FFFFFF;
  border-color: transparent;
  box-shadow: 0 2px 6px rgba(93, 168, 208, 0.20);
}

.category-tag-add {
  color: var(--color-primary);
  border-color: rgba(93, 168, 208, 0.25);
  background-color: var(--color-primary-bg);
  min-width: 36px;
  text-align: center;
  font-size: var(--font-body-size);
}

/* 分类空状态 */
.category-empty {
  padding: var(--space-md) var(--space-lg);
  background-color: var(--color-surface);
  border-radius: var(--radius-input);
  border: 1px dashed rgba(93, 168, 208, 0.15);
  font-size: var(--font-caption-size);
  color: var(--color-text-tertiary);
}

.category-empty-link {
  color: var(--color-primary);
  font-weight: 600;
  text-decoration: underline;
}

/* 日期选择器 */
.picker-value {
  display: flex;
  align-items: center;
}

.placeholder {
  color: var(--color-text-tertiary);
}

/* 过期时间预览 */
.expiry-preview {
  margin-top: calc(-1 * var(--space-sm));
  margin-bottom: var(--space-lg);
}

.expiry-preview-inner {
  background: linear-gradient(135deg, var(--color-info-bg), rgba(226, 241, 248, 0.5));
  border-radius: var(--radius-input);
  padding: var(--space-md) var(--space-lg);
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1px solid rgba(107, 174, 208, 0.12);
}

.expiry-label {
  font-size: var(--font-caption-size);
  color: #3A8DBF;
  font-weight: 600;
}

.expiry-date {
  font-size: var(--font-body-size);
  color: #2171A8;
  font-weight: 700;
}

/* 开封区域 */
.opened-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.toggle-icon {
  font-size: var(--font-caption-size);
  color: var(--color-primary);
  font-weight: 600;
}

/* 保存按钮 — 渐变天空蓝 */
.save-section {
  padding: var(--space-lg) 0;
}

.btn-save {
  width: 100%;
  height: 48px;
  line-height: 48px;
  font-size: var(--font-h3-size);
  padding: 0;
  box-shadow: 0 4px 16px rgba(93, 168, 208, 0.30);
}

.btn-save[disabled] {
  opacity: 0.55;
}
