/**
 * 首页样式
 * 设计参考: design-system/MASTER.md + design-system/pages/home.md
 */

.page-home {
  padding-bottom: 80px;
  min-height: 100vh;
}

/* 顶部渐变区域 */
.home-header {
  position: relative;
  background: linear-gradient(135deg, #FFF0F3 0%, #EDE9FE 50%, #DCFCE7 100%);
  padding: var(--space-xl) var(--space-lg) var(--space-2xl);
  overflow: hidden;
}

.home-title {
  display: block;
  font-size: var(--font-h1-size);
  font-weight: 800;
  line-height: 1.3;
  color: var(--color-text-primary);
  margin-bottom: var(--space-xl);
  position: relative;
  z-index: 1;
}

/* 几何装饰 */
.geo-circle {
  position: absolute;
  border-radius: var(--radius-full);
}

.geo-1 {
  width: 120px;
  height: 120px;
  background-color: rgba(255, 107, 138, 0.08);
  top: -30px;
  right: -20px;
}

.geo-rect {
  position: absolute;
  border-radius: 6px;
  transform: rotate(20deg);
}

.geo-2 {
  width: 40px;
  height: 40px;
  background-color: rgba(139, 92, 246, 0.08);
  top: 20px;
  right: 80px;
}

.geo-triangle {
  position: absolute;
  width: 0;
  height: 0;
  border-left: 25px solid transparent;
  border-right: 25px solid transparent;
  border-bottom: 43px solid rgba(52, 211, 153, 0.07);
}

.geo-3 {
  bottom: 30px;
  left: 20px;
}

/* 统计卡片行 */
.stat-row {
  display: flex;
  gap: var(--space-sm);
  position: relative;
  z-index: 1;
}

.stat-card {
  flex: 1;
  border-radius: var(--radius-card);
  padding: var(--space-md);
  text-align: center;
  box-shadow: var(--shadow-card);
}

.stat-safe {
  background: linear-gradient(135deg, #DCFCE7, #A7F3D0);
}

.stat-warning {
  background: linear-gradient(135deg, #FEF3C7, #FDE68A);
}

.stat-rate {
  background: linear-gradient(135deg, #EDE9FE, #C4B5FD);
}

.stat-num {
  display: block;
  font-size: var(--font-stat-size);
  font-weight: 800;
  line-height: 1.2;
  color: var(--color-text-primary);
}

.stat-unit {
  font-size: var(--font-body-size);
}

.stat-label {
  display: block;
  font-size: var(--font-small-size);
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-top: 2px;
}

/* 区块标题 */
.section {
  padding: var(--space-xl) var(--space-lg) 0;
}

.section-title {
  display: block;
  font-size: var(--font-h2-size);
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: var(--space-md);
}

/* 即将过期警告卡片 */
.warning-card {
  margin-bottom: var(--space-md);
  border-left: 4px solid transparent;
}

.border-warning {
  border-left-color: var(--color-warning);
}

.border-danger {
  border-left-color: var(--color-danger);
}

.warning-card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-sm);
}

.warning-info {
  flex: 1;
}

.warning-name {
  display: block;
  font-size: var(--font-h3-size);
  font-weight: 700;
  color: var(--color-text-primary);
}

.warning-meta {
  display: block;
  font-size: var(--font-caption-size);
  color: var(--color-text-secondary);
  margin-top: 2px;
}

.warning-days {
  text-align: right;
  flex-shrink: 0;
  margin-left: var(--space-md);
}

.warning-days-num {
  display: block;
  font-size: 22px;
  font-weight: 800;
  line-height: 1.2;
  color: var(--color-text-primary);
}

.warning-days-unit {
  display: block;
  font-size: var(--font-small-size);
  font-weight: 600;
  color: var(--color-text-secondary);
}

/* 安全提示 */
.safe-banner {
  margin: var(--space-xl) var(--space-lg) 0;
  background-color: var(--color-safe-bg);
  text-align: center;
}

.safe-text {
  font-size: var(--font-body-size);
  font-weight: 600;
  color: #059669;
}

/* 最近添加 */
.recent-card {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  margin-bottom: var(--space-sm);
  padding: var(--space-md) var(--space-lg);
}

.recent-icon {
  width: 36px;
  height: 36px;
  border-radius: var(--radius-icon);
  background: linear-gradient(135deg, var(--color-primary-bg), var(--color-secondary-bg));
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.recent-icon-text {
  font-size: 14px;
  font-weight: 800;
  color: var(--color-primary);
}

.recent-info {
  flex: 1;
  overflow: hidden;
}

.recent-name {
  display: block;
  font-size: var(--font-body-size);
  font-weight: 700;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-meta {
  display: block;
  font-size: var(--font-caption-size);
  color: var(--color-text-secondary);
}

.recent-time {
  flex-shrink: 0;
  font-size: var(--font-small-size);
  font-weight: 600;
  color: var(--color-text-tertiary);
}

.view-all {
  text-align: center;
  padding: var(--space-md) 0;
}

.view-all-text {
  font-size: var(--font-caption-size);
  font-weight: 600;
  color: var(--color-primary);
}

/* 空状态 */
.empty-home {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px var(--space-lg);
}

.empty-icon {
  width: 80px;
  height: 80px;
  border-radius: var(--radius-full);
  background: linear-gradient(135deg, var(--color-primary-bg), var(--color-secondary-bg));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-lg);
}

.empty-icon-text {
  font-size: 36px;
  font-weight: 300;
  color: var(--color-primary);
}

.empty-title {
  font-size: var(--font-h3-size);
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: var(--space-xs);
}

.empty-desc {
  font-size: var(--font-caption-size);
  color: var(--color-text-secondary);
  margin-bottom: var(--space-xl);
  text-align: center;
}

.btn-empty {
  padding: var(--space-md) var(--space-2xl);
}

/* 加载中 */
.loading {
  text-align: center;
  padding: var(--space-2xl) 0;
}

.loading-text {
  font-size: var(--font-body-size);
  color: var(--color-text-tertiary);
}
