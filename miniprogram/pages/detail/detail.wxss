/**
 * 产品详情页样式
 * 设计参考: design-system/MASTER.md + design-system/pages/detail.md
 */

.page-detail {
  padding: var(--space-lg);
  padding-bottom: 40px;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 产品头部卡片 */
.detail-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-xl) var(--space-lg);
  margin-bottom: var(--space-lg);
}

.header-icon {
  width: 64px;
  height: 64px;
  border-radius: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-md);
}

.icon-safe { background: linear-gradient(135deg, #DCFCE7, #A7F3D0); }
.icon-warning { background: linear-gradient(135deg, #FEF3C7, #FDE68A); }
.icon-danger { background: linear-gradient(135deg, #FEE2E2, #FCA5A5); }
.icon-secondary { background: linear-gradient(135deg, #F3F4F6, #E5E7EB); }

.header-icon-text {
  font-size: 28px;
  font-weight: 800;
  color: var(--color-text-primary);
}

.header-brand {
  font-size: var(--font-caption-size);
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 2px;
}

.header-name {
  font-size: var(--font-h2-size);
  font-weight: 700;
  color: var(--color-text-primary);
  text-align: center;
  margin-bottom: var(--space-sm);
}

.header-tags {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.header-category-tag {
  padding: var(--space-xs) 10px;
  border-radius: var(--radius-tag);
  background-color: var(--color-primary-bg);
  color: var(--color-primary);
  font-size: 11px;
  font-weight: 600;
}

.header-spec {
  font-size: var(--font-caption-size);
  color: var(--color-text-secondary);
}

/* 保质期状态卡片 */
.expiry-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-xl) var(--space-lg);
  margin-bottom: var(--space-lg);
}

.expiry-safe { background-color: var(--color-safe-bg); }
.expiry-warning { background-color: var(--color-warning-bg); }
.expiry-danger { background-color: var(--color-danger-bg); }
.expiry-secondary { background-color: #F3F4F6; }

.expiry-remaining-num {
  font-size: 28px;
  font-weight: 800;
  line-height: 1.2;
  color: var(--color-text-primary);
}

.expiry-remaining-unit {
  font-size: var(--font-caption-size);
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 2px;
}

.expiry-remaining-desc {
  font-size: var(--font-body-size);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--space-lg);
}

.detail-progress-bar {
  width: 100%;
  height: 8px;
  background-color: rgba(0,0,0,0.08);
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: var(--space-lg);
}

.detail-progress-fill {
  height: 100%;
  border-radius: 4px;
  transition: width 400ms ease-out;
}

.expiry-dates {
  width: 100%;
}

.date-row {
  display: flex;
  justify-content: space-between;
  padding: var(--space-xs) 0;
}

.date-label {
  font-size: var(--font-caption-size);
  color: var(--color-text-secondary);
}

.date-value {
  font-size: var(--font-caption-size);
  font-weight: 600;
  color: var(--color-text-primary);
}

/* 详细信息卡片 */
.info-card {
  margin-bottom: var(--space-lg);
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: var(--space-sm) 0;
  border-bottom: 1px solid var(--color-border);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: var(--font-body-size);
  color: var(--color-text-secondary);
}

.info-value {
  font-size: var(--font-body-size);
  font-weight: 600;
  color: var(--color-text-primary);
}

.info-link {
  color: var(--color-primary);
}

/* 操作按钮区 */
.action-section {
  margin-bottom: var(--space-lg);
}

.action-row {
  display: flex;
  gap: var(--space-md);
}

.btn-action {
  flex: 1;
  height: 44px;
  line-height: 44px;
  border-radius: var(--radius-button);
  font-size: var(--font-body-size);
  font-weight: 600;
  text-align: center;
  border: none;
  padding: 0;
}

.btn-action::after {
  border: none;
}

.btn-used {
  background-color: #F3F4F6;
  color: var(--color-text-secondary);
}

.btn-discard {
  background-color: #F3F4F6;
  color: var(--color-text-secondary);
}

.done-badge {
  text-align: center;
  padding: var(--space-md);
  border-radius: var(--radius-button);
  background-color: #F3F4F6;
}

.done-text {
  font-size: var(--font-body-size);
  font-weight: 600;
  color: var(--color-text-tertiary);
}

/* 删除按钮 */
.delete-section {
  padding-top: var(--space-lg);
  border-top: 1px solid var(--color-border);
}

.btn-delete {
  width: 100%;
  height: 44px;
  line-height: 44px;
  background-color: transparent;
  color: var(--color-danger);
  font-size: var(--font-body-size);
  font-weight: 600;
  border: none;
  padding: 0;
}

.btn-delete::after {
  border: none;
}

/* 加载/错误页 */
.loading-page,
.error-page {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-text {
  font-size: var(--font-body-size);
  color: var(--color-text-tertiary);
}

.error-text {
  font-size: var(--font-body-size);
  color: var(--color-danger);
}
