/**
 * 产品详情页样式 — 暖暖梦幻版
 * 天蓝系图标 + 渐变状态卡片 + 柔和按钮
 */

.page-detail {
  padding: var(--space-lg);
  padding-bottom: 40px;
  min-height: 100vh;
  box-sizing: border-box;
  background: var(--color-bg);
}

/* 产品头部卡片 */
.detail-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-xl) var(--space-lg);
  margin-bottom: var(--space-lg);
}

.header-icon {
  width: 64px;
  height: 64px;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-md);
}

.icon-safe { background: linear-gradient(145deg, #DCF5EB, #A8E6CF); }
.icon-warning { background: linear-gradient(145deg, #FDF3DC, #F0CA8A); }
.icon-danger { background: linear-gradient(145deg, #FCE8E4, #F0A0A0); }
.icon-secondary { background: linear-gradient(145deg, #F0F3F5, #DDE2E7); }

.header-icon-text {
  font-size: 28px;
  font-weight: 800;
  color: var(--color-text-primary);
}

.header-brand {
  font-size: var(--font-caption-size);
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 2px;
}

.header-name {
  font-size: var(--font-h2-size);
  font-weight: 700;
  color: var(--color-text-primary);
  text-align: center;
  margin-bottom: var(--space-sm);
}

.header-tags {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.header-category-tag {
  padding: var(--space-xs) 10px;
  border-radius: var(--radius-tag);
  background-color: var(--color-primary-bg);
  color: var(--color-primary);
  font-size: 11px;
  font-weight: 600;
}

.header-spec {
  font-size: var(--font-caption-size);
  color: var(--color-text-secondary);
}

.header-source-tag {
  padding: var(--space-xs) 8px;
  border-radius: var(--radius-tag);
  font-size: 11px;
  font-weight: 500;
  border: 1px solid;
}

.header-source-tag.source-link {
  background-color: rgba(76, 184, 156, 0.12);
  color: #2D9B72;
  border-color: rgba(76, 184, 156, 0.20);
}

.header-source-tag.source-manual {
  background-color: rgba(232, 168, 56, 0.10);
  color: #C87D0A;
  border-color: rgba(232, 168, 56, 0.20);
}

/* 保质期状态卡片 — 柔和渐变背景 */
.expiry-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-xl) var(--space-lg);
  margin-bottom: var(--space-lg);
}

.expiry-safe { background: linear-gradient(135deg, #F2FCF7, #DFF5EA); }
.expiry-warning { background: linear-gradient(135deg, #FEFBF0, #FDF0D6); }
.expiry-danger { background: linear-gradient(135deg, #FDF2F1, #FAE0DD); }
.expiry-secondary { background: linear-gradient(135deg, #F4F5F6, #EBEEF0); }

.expiry-remaining-num {
  font-size: 28px;
  font-weight: 800;
  line-height: 1.2;
  color: var(--color-text-primary);
}

.expiry-remaining-unit {
  font-size: var(--font-caption-size);
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 2px;
}

.expiry-remaining-desc {
  font-size: var(--font-body-size);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--space-lg);
}

.detail-progress-bar {
  width: 100%;
  height: 8px;
  background-color: rgba(93, 168, 208, 0.08);
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: var(--space-lg);
}

.detail-progress-fill {
  height: 100%;
  border-radius: 4px;
  transition: width 400ms ease-out;
}

.expiry-dates {
  width: 100%;
}

.date-row {
  display: flex;
  justify-content: space-between;
  padding: var(--space-xs) 0;
}

.date-label {
  font-size: var(--font-caption-size);
  color: var(--color-text-secondary);
}

.date-value {
  font-size: var(--font-caption-size);
  font-weight: 600;
  color: var(--color-text-primary);
}

/* 详细信息卡片 */
.info-card {
  margin-bottom: var(--space-lg);
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: var(--space-sm) 0;
  border-bottom: 1px solid rgba(93, 168, 208, 0.06);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: var(--font-body-size);
  color: var(--color-text-secondary);
}

.info-value {
  font-size: var(--font-body-size);
  font-weight: 600;
  color: var(--color-text-primary);
}

.info-link {
  color: var(--color-primary);
}

/* 操作按钮区 — 天蓝风格 */
.action-section {
  margin-bottom: var(--space-lg);
}

.action-row {
  display: flex;
  gap: var(--space-md);
}

.btn-action {
  flex: 1;
  height: 44px;
  line-height: 44px;
  border-radius: var(--radius-button);
  font-size: var(--font-body-size);
  font-weight: 600;
  text-align: center;
  border: none;
  padding: 0;
  transition: transform 150ms ease;
}

.btn-action::after {
  border: none;
}

.btn-action:active {
  transform: scale(0.97);
}

.btn-edit {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: #FFFFFF;
  box-shadow: 0 3px 10px rgba(93, 168, 208, 0.25);
}

.btn-used {
  background-color: #F0F3F5;
  color: var(--color-text-secondary);
  border: 1px solid rgba(93, 168, 208, 0.08);
}

.btn-discard {
  background-color: #F0F3F5;
  color: var(--color-text-secondary);
  border: 1px solid rgba(93, 168, 208, 0.08);
}

.action-row + .action-row {
  margin-top: var(--space-md);
}

.done-row {
  display: flex;
  gap: var(--space-md);
  align-items: center;
}

.done-row .done-badge {
  flex: 1;
}

.done-row .btn-action {
  flex: 1;
}

.done-badge {
  text-align: center;
  padding: var(--space-md);
  border-radius: var(--radius-button);
  background-color: #F0F3F5;
  border: 1px solid rgba(93, 168, 208, 0.08);
}

.done-text {
  font-size: var(--font-body-size);
  font-weight: 600;
  color: var(--color-text-tertiary);
}

/* 删除按钮 */
.delete-section {
  padding-top: var(--space-lg);
  border-top: 1px solid rgba(93, 168, 208, 0.08);
}

.btn-delete {
  width: 100%;
  height: 44px;
  line-height: 44px;
  background-color: transparent;
  color: var(--color-danger);
  font-size: var(--font-body-size);
  font-weight: 600;
  border: none;
  padding: 0;
}

.btn-delete::after {
  border: none;
}

/* 加载/错误页 */
.loading-page,
.error-page {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-text {
  font-size: var(--font-body-size);
  color: var(--color-text-tertiary);
}

.error-text {
  font-size: var(--font-body-size);
  color: var(--color-danger);
}
