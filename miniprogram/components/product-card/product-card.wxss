/**
 * 产品卡片组件样式 — 暖暖梦幻版
 * 柔和圆角 + 天蓝系图标 + 渐变进度条
 */

.product-card {
  margin-bottom: var(--space-md);
  border: 1px solid rgba(93, 168, 208, 0.06);
  transition: transform 200ms ease, box-shadow 200ms ease;
}

.product-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-card-hover);
}

.card-top {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  margin-bottom: var(--space-md);
}

/* 图标容器 — 更圆润柔和 */
.card-icon {
  width: 46px;
  height: 46px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-safe {
  background: linear-gradient(145deg, #DCF5EB, #A8E6CF);
}

.icon-warning {
  background: linear-gradient(145deg, #FDF3DC, #F0CA8A);
}

.icon-danger {
  background: linear-gradient(145deg, #FCE8E4, #F0A0A0);
}

.icon-secondary {
  background: linear-gradient(145deg, #F0F3F5, #DDE2E7);
}

.icon-text {
  font-size: 18px;
  font-weight: 800;
  color: var(--color-text-primary);
}

/* 产品信息 */
.card-info {
  flex: 1;
  overflow: hidden;
}

.card-name {
  display: block;
  font-size: var(--font-h3-size);
  font-weight: 700;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-meta {
  display: block;
  font-size: var(--font-caption-size);
  color: var(--color-text-secondary);
  margin-top: 2px;
}

.card-source-icon {
  font-size: 11px;
  margin-left: 4px;
  opacity: 0.65;
}

/* 状态标签 — 圆润药丸状 */
.status-tag {
  flex-shrink: 0;
  padding: var(--space-xs) 10px;
  border-radius: var(--radius-tag);
  font-size: 11px;
  font-weight: 600;
}

.tag-safe {
  background-color: var(--color-safe-bg);
  color: #2D9B72;
}

.tag-warning {
  background-color: var(--color-warning-bg);
  color: #C87D0A;
}

.tag-danger {
  background-color: var(--color-danger-bg);
  color: #C74B4B;
}

.tag-secondary {
  background-color: #EEF2F5;
  color: var(--color-text-secondary);
}

/* 底部进度 */
.card-bottom {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.card-bottom .progress-bar {
  flex: 1;
}

.remaining-text {
  flex-shrink: 0;
  font-size: var(--font-small-size);
  font-weight: 600;
}

.text-safe { color: #2D9B72; }
.text-warning { color: #C87D0A; }
.text-danger { color: #C74B4B; }
.text-secondary { color: var(--color-text-secondary); }
