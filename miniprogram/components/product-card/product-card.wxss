/**
 * 产品卡片组件样式
 */

.product-card {
  margin-bottom: var(--space-md);
}

.card-top {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  margin-bottom: var(--space-md);
}

/* 图标容器 */
.card-icon {
  width: 44px;
  height: 44px;
  border-radius: var(--radius-icon);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-safe {
  background: linear-gradient(135deg, #DCFCE7, #A7F3D0);
}

.icon-warning {
  background: linear-gradient(135deg, #FEF3C7, #FDE68A);
}

.icon-danger {
  background: linear-gradient(135deg, #FEE2E2, #FCA5A5);
}

.icon-secondary {
  background: linear-gradient(135deg, #F3F4F6, #E5E7EB);
}

.icon-text {
  font-size: 18px;
  font-weight: 800;
  color: var(--color-text-primary);
}

/* 产品信息 */
.card-info {
  flex: 1;
  overflow: hidden;
}

.card-name {
  display: block;
  font-size: var(--font-h3-size);
  font-weight: 700;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-meta {
  display: block;
  font-size: var(--font-caption-size);
  color: var(--color-text-secondary);
  margin-top: 2px;
}

.card-source-icon {
  font-size: 11px;
  margin-left: 4px;
  opacity: 0.7;
}

/* 状态标签 */
.status-tag {
  flex-shrink: 0;
  padding: var(--space-xs) 10px;
  border-radius: var(--radius-tag);
  font-size: 11px;
  font-weight: 600;
}

.tag-safe {
  background-color: var(--color-safe-bg);
  color: #059669;
}

.tag-warning {
  background-color: var(--color-warning-bg);
  color: #D97706;
}

.tag-danger {
  background-color: var(--color-danger-bg);
  color: #DC2626;
}

.tag-secondary {
  background-color: #F3F4F6;
  color: var(--color-text-secondary);
}

/* 底部进度 */
.card-bottom {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.card-bottom .progress-bar {
  flex: 1;
}

.remaining-text {
  flex-shrink: 0;
  font-size: var(--font-small-size);
  font-weight: 600;
}

.text-safe { color: #059669; }
.text-warning { color: #D97706; }
.text-danger { color: #DC2626; }
.text-secondary { color: var(--color-text-secondary); }
