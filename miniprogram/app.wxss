/**
 * CosmeticBox 全局样式 — 暖暖梦幻风格版
 * 设计灵感: 暖暖角色 · 天空蓝 + 薄荷绿 + 奶油白
 * 视觉关键词: 梦幻、自然、童话、柔和光效
 */

page {
  /* 主色 · Primary（天空蓝 Sky Blue） */
  --color-primary: #5BA8D0;
  --color-primary-light: #7EC8E3;
  --color-primary-lighter: #B0DDE9;
  --color-primary-bg: #E8F4FC;

  /* 辅色 · Secondary（薄荷绿 Mint Green） */
  --color-secondary: #5DB89C;
  --color-secondary-light: #7DD3B5;
  --color-secondary-lighter: #A8E6CF;
  --color-secondary-bg: #E2F6ED;

  /* 强调色 · Accent（柔金 Warm Gold） */
  --color-accent: #E8B86D;
  --color-accent-light: #F0CA8A;
  --color-accent-bg: #FBF3E4;

  /* 语义色 · Semantic（保持功能区分，但融入新色调） */
  --color-safe: #4CB89C;
  --color-safe-bg: #DCF5EB;
  --color-warning: #E8A838;
  --color-warning-bg: #FDF3DC;
  --color-danger: #E87C7C;
  --color-danger-bg: #FCE8E6;
  --color-info: #6BAED0;
  --color-info-bg: #E2F1F8;

  /* 底色 · Surfaces（奶油白系） */
  --color-bg: #FDFFFA;
  --color-surface: #FFFFFF;
  --color-text-primary: #2D3436;
  --color-text-secondary: #636E72;
  --color-text-tertiary: #A0AEB5;
  --color-border: rgba(93, 168, 208, 0.12);

  /* 圆角 — 更圆润的童话感 */
  --radius-card: 20px;
  --radius-button: 14px;
  --radius-icon: 14px;
  --radius-input: 14px;
  --radius-tag: 10px;
  --radius-progress: 4px;
  --radius-full: 9999px;

  /* 阴影 — 更柔和的梦幻阴影 */
  --shadow-card: 0 3px 16px rgba(93, 168, 208, 0.08);
  --shadow-card-hover: 0 6px 24px rgba(93, 168, 208, 0.14);
  --shadow-float: 0 10px 32px rgba(93, 168, 208, 0.18);
  --shadow-glow: 0 0 20px rgba(93, 184, 156, 0.15);

  /* 间距 */
  --space-xs: 4px;
  --space-sm: 8px;
  --space-md: 12px;
  --space-lg: 16px;
  --space-xl: 24px;
  --space-2xl: 32px;

  /* 字体 */
  --font-h1-size: 28px;
  --font-h2-size: 20px;
  --font-h3-size: 16px;
  --font-body-size: 14px;
  --font-caption-size: 12px;
  --font-small-size: 10px;
  --font-stat-size: 24px;

  /* 全局基础样式 */
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue",
               "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: var(--font-body-size);
  color: var(--color-text-primary);
  background-color: var(--color-bg);
  line-height: 1.5;
}

/* ====== 通用工具类 ====== */

.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-tertiary { color: var(--color-text-tertiary); }
.text-safe { color: var(--color-safe); }
.text-warning { color: var(--color-warning); }
.text-danger { color: var(--color-danger); }

.bg-primary { background-color: var(--color-primary-bg); }
.bg-secondary { background-color: var(--color-secondary-bg); }
.bg-safe { background-color: var(--color-safe-bg); }
.bg-warning { background-color: var(--color-warning-bg); }
.bg-danger { background-color: var(--color-danger-bg); }
.bg-surface { background-color: var(--color-surface); }

.font-h1 {
  font-size: var(--font-h1-size);
  font-weight: 800;
  line-height: 1.3;
}

.font-h2 {
  font-size: var(--font-h2-size);
  font-weight: 700;
  line-height: 1.4;
}

.font-h3 {
  font-size: var(--font-h3-size);
  font-weight: 700;
  line-height: 1.5;
}

.font-body {
  font-size: var(--font-body-size);
  font-weight: 400;
  line-height: 1.5;
}

.font-caption {
  font-size: var(--font-caption-size);
  font-weight: 600;
  line-height: 1.4;
}

.font-stat {
  font-size: var(--font-stat-size);
  font-weight: 800;
  line-height: 1.2;
}

/* 卡片基础样式 — 梦幻柔和风格 */
.card {
  background-color: var(--color-surface);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  padding: var(--space-lg);
  border: 1px solid rgba(93, 168, 208, 0.06);
}

/* 按钮基础样式 — 渐变天空蓝 */
.btn-primary {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-button);
  padding: var(--space-md) var(--space-lg);
  font-size: var(--font-body-size);
  font-weight: 700;
  text-align: center;
  line-height: 1.5;
  box-shadow: 0 3px 12px rgba(93, 168, 208, 0.25);
}

.btn-primary::after {
  border: none;
}

/* 输入框基础样式 */
.input {
  background-color: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-input);
  padding: var(--space-md) var(--space-lg);
  font-size: var(--font-body-size);
  color: var(--color-text-primary);
  height: 44px;
  box-sizing: border-box;
  transition: border-color 200ms ease;
}

/* 标签基础样式 */
.tag {
  display: inline-block;
  padding: var(--space-xs) 10px;
  border-radius: var(--radius-tag);
  font-size: 11px;
  font-weight: 600;
}

/* 进度条基础样式 — 圆润渐变 */
.progress-bar {
  height: 7px;
  background-color: #E8F0F3;
  border-radius: var(--radius-progress);
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  border-radius: var(--radius-progress);
  transition: width 400ms ease-out;
}

.progress-safe {
  background: linear-gradient(90deg, #4CB89C, #7DD3B5);
}

.progress-warning {
  background: linear-gradient(90deg, #E8A838, #F0CA8A);
}

.progress-danger {
  background: linear-gradient(90deg, #E87C7C, #F0A0A0);
}
